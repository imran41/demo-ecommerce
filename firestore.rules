rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read: if true; // Public read for user profiles (names, roles)
      allow create: if isAuthenticated() && request.auth.uid == userId; // Allow creation during sign-up
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId); // Owner or admin can update
      allow delete: if isAdmin(); // Only admins can delete profiles
    }

    // 2. Products collection rules
    match /products/{productId} {
      allow read: if resource.data.status == 'active' || isAdmin(); // Public read for active, admins see all
      allow write: if isAdmin(); // Only admins can add, edit, or delete products
    }

    // 3. Orders collection rules
    match /orders/{orderId} {
      allow create: if true; // Allow guest checkout and authenticated users to submit orders
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid); // Admins or owners
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid); // Admins or owners (e.g. returns)
      allow delete: if isAdmin(); // Only admins can hard-delete order records
    }

    // 4. Reviews collection rules
    match /reviews/{reviewId} {
      allow read: if true; // Public read for product reviews
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid; // Only write own reviews
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid; // Only owner can update comment
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid); // Owner or admin
    }

    // 5. Wishlist collection rules
    match /wishlist/{wishlistId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid; // Fully isolated per user
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
